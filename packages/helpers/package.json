{
  "name": "@jeffgo10/helpers",
  "version": "0.4.1",
  "description": "Shared helper utilities for ls-foundry packages",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffgo10/ls-foundry.git",
    "directory": "packages/helpers"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },
    "./clipboard": {
      "types": "./dist/clipboard.d.ts",
      "import": "./dist/clipboard.js",
      "require": "./dist/clipboard.cjs"
    },
    "./gestures": {
      "types": "./dist/gestures.d.ts",
      "import": "./dist/gestures.js",
      "require": "./dist/gestures.cjs"
    },
    "./image": {
      "types": "./dist/image.d.ts",
      "import": "./dist/image.js",
      "require": "./dist/image.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@ls-foundry/test-utils": "workspace:*",
    "@ls-foundry/tsconfig": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
