{
  "name": "@ls-foundry/helpers",
  "version": "0.1.0",
  "private": true,
  "description": "Shared helper utilities for ls-foundry packages",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./image": {
      "types": "./dist/image.d.ts",
      "import": "./dist/image.js",
      "require": "./dist/image.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@ls-foundry/tsconfig": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
