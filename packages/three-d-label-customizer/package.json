{
  "name": "@jeffgo10/three-d-label-customizer",
  "version": "0.1.0",
  "description": "React Three Fiber component: neon-green area scan + curved 3D label texture warping",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffgo10/ls-foundry.git",
    "directory": "packages/three-d-label-customizer"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "three": ">=0.170.0 <1.0.0"
  },
  "dependencies": {
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "@ls-foundry/test-utils": "workspace:*",
    "@ls-foundry/tsconfig": "workspace:*",
    "@react-three/drei": "^10.0.6",
    "@react-three/fiber": "^9.1.2",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.183.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.183.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
