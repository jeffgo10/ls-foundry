{
  "name": "@jeffgo10/canvas-upscaler",
  "version": "0.1.1",
  "description": "Map StickPak 72 DPI layout JSON to a 300 DPI print PNG",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffgo10/ls-foundry.git",
    "directory": "packages/canvas-upscaler"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test:export": "tsx scripts/test-export.ts",
    "test:json": "tsx scripts/upscale-from-json.ts",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@jeffgo10/shared-types": "workspace:*",
    "canvas": "^3.1.0"
  },
  "devDependencies": {
    "@ls-foundry/test-utils": "workspace:*",
    "@ls-foundry/tsconfig": "workspace:*",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
