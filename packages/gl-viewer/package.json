{
  "name": "@jeffgo10/gl-viewer",
  "version": "0.3.1",
  "description": "React GLB / LiDAR viewer (Three.js): orbit, walk, WebXR AR",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffgo10/ls-foundry.git",
    "directory": "packages/gl-viewer"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "three": ">=0.170.0 <1.0.0"
  },
  "devDependencies": {
    "@ls-foundry/tsconfig": "workspace:*",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.183.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.183.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
