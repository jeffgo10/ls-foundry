{
  "name": "@ls-foundry/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "StickPak canvas layout types and print dimension constants",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@ls-foundry/tsconfig": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
