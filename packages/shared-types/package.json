{
  "name": "@jeffgo10/shared-types",
  "version": "0.2.4",
  "description": "StickPak canvas layout types and print dimension constants",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffgo10/ls-foundry.git",
    "directory": "packages/shared-types"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@ls-foundry/tsconfig": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
