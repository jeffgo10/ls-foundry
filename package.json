{
  "name": "ls-foundry",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "deploy": "pnpm --filter @jeffgo10/gl-viewer publish --access public",
    "deploy:dry-run": "pnpm --filter @jeffgo10/gl-viewer publish --access public --dry-run",
    "deploy:nogit": "pnpm --filter @jeffgo10/gl-viewer publish --access public --no-git-checks"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
